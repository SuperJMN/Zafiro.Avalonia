<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shell="clr-namespace:Zafiro.UI.Shell;assembly=Zafiro.UI"
             xmlns:sections="clr-namespace:Zafiro.UI.Navigation.Sections;assembly=Zafiro.UI"
             xmlns:nav="clr-namespace:Zafiro.Avalonia.Controls.Navigation"
             xmlns:local="clr-namespace:Zafiro.Avalonia.Controls.Shell"
             xmlns:primitives="clr-namespace:Avalonia.Controls.Primitives;assembly=Avalonia.Controls"
             xmlns:zac="clr-namespace:Zafiro.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Zafiro.Avalonia.Controls.Shell.ShellView"
             x:Name="ShellViewRoot"
             x:DataType="shell:IHierarchicalShell">

    <UserControl.Resources>
        <ControlTheme x:Key="{x:Type local:SectionTreeView}"
                      TargetType="local:SectionTreeView"
                      BasedOn="{StaticResource {x:Type TreeView}}" />

        <ControlTheme x:Key="{x:Type local:ShellFrame}"
                      TargetType="local:ShellFrame"
                      BasedOn="{StaticResource {x:Type nav:Frame}}" />

        <DataTemplate x:Key="MobileChildLevelTemplate" DataType="shell:SectionLevel">
            <primitives:TabStrip IsVisible="{Binding Sections, Converter={x:Static local:ShellConverters.HasMultipleSections}}"
                                 ItemsSource="{Binding Sections}"
                                 SelectedItem="{Binding SelectedSection.Value, Mode=TwoWay}">
                <primitives:TabStrip.ItemTemplate>
                    <DataTemplate DataType="sections:ISection" x:CompileBindings="False">
                        <TextBlock Text="{Binding FriendlyName}"
                                   TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </primitives:TabStrip.ItemTemplate>
            </primitives:TabStrip>
        </DataTemplate>

        <TreeDataTemplate x:Key="DesktopSectionTreeNodeTemplate"
                          DataType="local:SectionTreeNode"
                          ItemsSource="{Binding Children}"
                          x:CompileBindings="False">
            <DockPanel Margin="5"
                       HorizontalSpacing="10">
                <Viewbox Height="28" Width="28">
                    <ContentControl Content="{Binding Icon}" />
                </Viewbox>
                <TextBlock VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding FriendlyName}" />
            </DockPanel>
        </TreeDataTemplate>
    </UserControl.Resources>

    <Design.DataContext>
        <local:ShellDesign />
    </Design.DataContext>

    <UserControl.Styles>
        <!-- Mobile-first defaults -->
        <Style Selector="FlexPanel#ShellLayout">
            <Setter Property="Direction" Value="ColumnReverse" />
        </Style>
        <Style Selector="Border#DesktopSidebar">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="zac|SectionStrip#ShellSectionStrip">
            <Setter Property="Orientation" Value="Horizontal" />
        </Style>
        <Style Selector="ContentControl#MobileChildTabs">
            <Setter Property="IsVisible" Value="True" />
        </Style>
    </UserControl.Styles>

    <!--
        Responsive shell:
        - Wide (>= 700): vertical SectionStrip on the left + content on the right.
        - Narrow (< 700): content on top, active child tabs above it, and root sections at the bottom.
    -->
    <Border Container.Name="shell" Container.Sizing="Width">
        <Border.Styles>
            <ContainerQuery Name="shell" Query="min-width:700">
                <Style Selector="FlexPanel#ShellLayout">
                    <Setter Property="Direction" Value="Row" />
                </Style>
                <Style Selector="Border#DesktopSidebar">
                    <Setter Property="IsVisible" Value="True" />
                </Style>
                <Style Selector="zac|SectionStrip#ShellSectionStrip">
                    <Setter Property="Orientation" Value="Vertical" />
                    <Setter Property="IsVisible" Value="False" />
                </Style>
                <Style Selector="ContentControl#MobileChildTabs">
                    <Setter Property="IsVisible" Value="False" />
                </Style>
            </ContainerQuery>
        </Border.Styles>

        <FlexPanel x:Name="ShellLayout" AlignItems="Stretch">
            <!-- Desktop section navigation: first level with all second-level children visible -->
            <Border x:Name="DesktopSidebar"
                    Width="220"
                    FlexPanel.Shrink="0">
                <local:SectionTreeView Shell="{Binding}"
                                       AutoScrollToSelectedItem="True"
                                       ItemTemplate="{StaticResource DesktopSectionTreeNodeTemplate}" />
            </Border>

            <!-- Mobile section navigation: bottom bar contains only the first level -->
            <zac:SectionStrip x:Name="ShellSectionStrip"
                              FlexPanel.Shrink="0"
                              Sections="{Binding RootLevel.Sections}"
                              SelectedSection="{Binding RootLevel.SelectedSection.Value, Mode=TwoWay}" />

            <!-- Content -->
            <FlexPanel FlexPanel.Grow="1" Direction="Column" AlignItems="Stretch">
                <ContentControl x:Name="MobileChildTabs"
                                FlexPanel.Shrink="0"
                                Content="{Binding ChildLevels.Value, Converter={x:Static local:ShellConverters.FirstChildLevel}}"
                                ContentTemplate="{StaticResource MobileChildLevelTemplate}" />

                <local:ShellFrame FlexPanel.Grow="1"
                                  Shell="{Binding}">
                    <Interaction.Behaviors>
                        <nav:AutoHeaderFooterBehavior />
                    </Interaction.Behaviors>
                </local:ShellFrame>
            </FlexPanel>
        </FlexPanel>
    </Border>
</UserControl>
