<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:generic="clr-namespace:System.Collections.Generic;assembly=System.Collections"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        xmlns:controls="clr-namespace:Zafiro.Avalonia.Controls">
    <Design.PreviewWith>
        <controls:MasterDetailsView Width="600" Height="500" Header="Header">
            <controls:MasterDetailsView.Footer>
                <TextBlock>Footer</TextBlock>
            </controls:MasterDetailsView.Footer>
            <controls:MasterDetailsView.ItemsSource>
                <generic:List x:TypeArguments="x:Object">
                    <system:String>Hola</system:String>
                    <system:String>Hola2</system:String>
                    <system:String>Hola3</system:String>
                </generic:List>
            </controls:MasterDetailsView.ItemsSource>
        </controls:MasterDetailsView>
    </Design.PreviewWith>

    <Style Selector="controls|MasterDetailsView">
        <Setter Property="Template">
            <ControlTemplate>
                <controls:ResponsivePresenter
                    Breakpoint="{Binding CompactWidth, RelativeSource={RelativeSource FindAncestor, AncestorType=controls:MasterDetailsView}}">
                    <controls:ResponsivePresenter.Wide>
                        <Grid ColumnDefinitions="Auto *" RowDefinitions="Auto * Auto">

                            <Border Background="{DynamicResource SoftBackgroundLists}" Grid.RowSpan="3" />

                            <ContentControl Grid.Row="0" Grid.Column="0"
                                            Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=Header}"
                                            ContentTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=HeaderTemplate}" />
                            <ListBox Grid.Row="1" Grid.Column="0" x:DataType="controls:MasterDetailsView"
                                     IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=!HasWideMasterTemplate}"
                                     ItemTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=ItemTemplate}"
                                     SelectedItem="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=SelectedItem, Mode=TwoWay}"
                                     ItemsSource="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=ItemsSource}"
                                     Background="Transparent"
                                     Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=MasterPaneWidth}"
                                     DockPanel.Dock="Left" />

                            <ContentControl Grid.Row="1" Grid.Column="0"
                                            IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=HasWideMasterTemplate}"
                                            Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=TemplateContext}"
                                            ContentTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=WideMasterTemplate}" />

                            <ScrollViewer Grid.Row="0" Grid.RowSpan="3" Grid.Column="1">
                                <Grid>
                                    <ContentControl
                                        IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=HasSelectedItem}"
                                        ContentTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=DetailsTemplate}"
                                        Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=SelectedItem}" />

                                    <Panel IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=!HasSelectedItem}">
                                        <ContentControl
                                            IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=HasEmptyTemplate}"
                                            Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=TemplateContext}"
                                            ContentTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=EmptyTemplate}" />
                                    </Panel>
                                </Grid>
                            </ScrollViewer>

                            <ContentControl Grid.Row="2" Grid.Column="0"
                                            Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=Footer}"
                                            ContentTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=FooterTemplate}" />
                        </Grid>
                    </controls:ResponsivePresenter.Wide>
                    <controls:ResponsivePresenter.Narrow>
                        <Panel>
                            <Border Background="{DynamicResource SoftBackgroundLists}" />

                            <DockPanel
                                IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=!AreDetailsShown}">

                                <ContentControl DockPanel.Dock="Top"
                                                Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=Header}"
                                                ContentTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=HeaderTemplate}" />

                                <ContentControl DockPanel.Dock="Bottom"
                                                Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=Footer}"
                                                ContentTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=FooterTemplate}" />

                                <Grid IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=!HasCompactMasterTemplate}">
                                    <ListBox x:DataType="controls:MasterDetailsView"
                                             IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=HasItems}"
                                             SelectedItem="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=SelectedItem,Mode=TwoWay}"
                                             ItemsSource="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=ItemsSource}"
                                             Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <EnhancedButton Classes="Expand"
                                                                Theme="{StaticResource FullTransparentButton}"
                                                                Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=OpenDetailsCommand}"
                                                                CommandParameter="{Binding}">
                                                    <ContentControl Content="{Binding}"
                                                                    ContentTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=EffectiveCompactItemTemplate}" />
                                                </EnhancedButton>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Panel IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=!HasItems}">
                                        <ContentControl
                                            IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=HasEmptyTemplate}"
                                            Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=TemplateContext}"
                                            ContentTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=EmptyTemplate}" />
                                    </Panel>
                                </Grid>

                                <ContentControl
                                    IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=HasCompactMasterTemplate}"
                                    Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=TemplateContext}"
                                    ContentTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=CompactMasterTemplate}" />
                            </DockPanel>

                            <ScrollViewer
                                IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=AreDetailsShown}">
                                <Grid>
                                    <ContentControl
                                        IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=HasSelectedItem}"
                                        ContentTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=DetailsTemplate}"
                                        Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=SelectedItem}" />

                                    <Panel IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=!HasSelectedItem}">
                                        <ContentControl
                                            IsVisible="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=HasEmptyTemplate}"
                                            Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=TemplateContext}"
                                            ContentTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=controls:MasterDetailsView}, Path=EmptyTemplate}" />
                                    </Panel>
                                </Grid>
                            </ScrollViewer>
                        </Panel>
                    </controls:ResponsivePresenter.Narrow>
                </controls:ResponsivePresenter>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
