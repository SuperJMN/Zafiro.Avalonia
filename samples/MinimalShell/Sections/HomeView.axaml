<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sections="clr-namespace:MinimalShell.Sections"
             x:Class="MinimalShell.Sections.HomeView" x:DataType="sections:HomeViewModel">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
        <PathIcon Data="{StaticResource fa-home}" Height="48" Width="48" />
        <TextBlock Text="{Binding Greeting}" FontSize="24" FontWeight="Light" HorizontalAlignment="Center" />
    </StackPanel>
</UserControl>
