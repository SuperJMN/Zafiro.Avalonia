<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sections="clr-namespace:ZafiroShellTemplate.Sections"
             x:Class="ZafiroShellTemplate.Sections.InvestorView" x:DataType="sections:InvestorViewModel">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
        <PathIcon Data="{StaticResource fa-user}" Height="64" Width="64" />
        <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
        <TextBlock Text="{Binding Description}" FontSize="14" Opacity="0.6" HorizontalAlignment="Center" TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
